{
  "name": "timechaingraph",
  "version": "0.0.1",
  "private": true,
  "description": "The brain of Bitcoin — privacy-first force-directed graph of every economically meaningful Bitcoin wallet at timechaingraph.com. Sister project: timechaingrid.com.",
  "license": "MIT",
  "author": "Timechaingraph team",
  "homepage": "https://timechaingraph.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/timechaingraph/timechaingraph.git"
  },
  "bugs": {
    "url": "https://github.com/timechaingraph/timechaingraph/issues"
  },
  "keywords": [
    "bitcoin",
    "blockchain",
    "visualization",
    "force-directed-graph",
    "pixijs",
    "nextjs",
    "privacy-first",
    "self-hosted",
    "wallet-graph"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "privacy-audit": "bash scripts/privacy-audit.sh out",
    "substrate:dump": "vitest run scripts/dump-substrate.test.ts",
    "vault:generate": "node chain-tools/vault/generate.mjs",
    "deploy": "next build && wrangler pages deploy out --project-name=timechaingraph --branch=main"
  },
  "dependencies": {
    "next": "^16.2.6",
    "pixi.js": "^8.18.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "wrangler": "^4"
  }
}
