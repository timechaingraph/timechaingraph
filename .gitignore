# dependencies
/node_modules
/.pnp
.pnp.*

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev artifacts
debug.log

# parquet snapshots fetched from CDN at dev time
public/data/

# DuckDB-Wasm runtime, vendored from node_modules at build time
# (scripts/copy-duckdb-assets.mjs); regenerated, never committed.
public/duckdb/

# Per-block state snapshots — auto-generated by chain-tools/vault/
# generate.mjs and served at /blocks/* for the canvas to fetch during
# Animate playback. Regenerated locally; never committed (the canonical
# copy lives under vault/blocks/ which is also gitignored).
# No trailing slash so the rule also matches the symlink to external
# storage (post-2026-05-09 cutover).
public/blocks
public/blocks.pre-cutover-backup
# Relocated cutover backup (moved out of public/ to keep it out of the
# static export bundle — would blow CF Pages 20k-file limit otherwise).
/.public-blocks.pre-cutover-backup

# chain-tools build artifacts (substrate dumps + parquet outputs from
# the operator pipeline) — regenerated locally, never committed.
# No trailing slash, so the rule also matches the `out` SYMLINK to the SSD
# (a trailing-slash rule matches only real dirs, not symlinks — that gap let a
# 617MB substrate backup get committed once on 2026-06-03; rewritten out of history).
/chain-tools/out
/chain-tools/out.pre-cutover-backup
/chain-tools/out.test

# Operator-side Python venv (duckdb + pyarrow for reduce_substrate.py /
# build_bundle.py) — large, regenerated via: python3 -m venv chain-tools/.venv
/chain-tools/.venv

# Python bytecode cache (anywhere in tree)
__pycache__/
*.pyc

# Operator-internal cross-project coordination script — local-only,
# never part of the public repo.
scripts/sync-sibling.sh

# Operator-internal records — local-only, NOT part of the public OSS repo.
# The entire corp/ tree is operator-private (matches the Grid sister's
# stance). The public-facing OSS standards (LICENSE, README, CONTRIBUTING,
# CODE_OF_CONDUCT, SECURITY) live at the repo root instead.
corp/

# Auto-generated Obsidian vault output. Per user directive 2026-04-30:
# "vault gitignored at all times". Both projections — vault/ (sister's
# brain), vault-grid/ (mine, coin substrate), vault-graph/ (post-rename
# target) — are build artifacts regenerated by chain-tools/vault/
# generate*.mjs. Hand-authored Prolog rules under each prolog/rules/
# subtree are the canonical contract; carve-outs below preserve them.
#
# Negation requires un-ignoring each ancestor along the path; using
# `vault*/*` (not `vault*/`) so subpaths can be un-ignored.
vault/*
!vault/prolog/
vault/prolog/*
!vault/prolog/rules/
!vault/prolog/rules/**
vault-grid/*
!vault-grid/prolog/
vault-grid/prolog/*
!vault-grid/prolog/rules/
!vault-grid/prolog/rules/**
vault-graph/*
!vault-graph/prolog/
vault-graph/prolog/*
!vault-graph/prolog/rules/
!vault-graph/prolog/rules/**
/x-banner.png
